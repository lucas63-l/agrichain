{
  "inputs": [
    {
      "type": "promptString",
      "id": "mongo-connection-string",
      "description": "MongoDB Atlas connection string",
      "password": true
    }
  ],
  "servers": {
    "MongoDB": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mongodb-mcp-server@latest"],
      "env": {
        "MDB_MCP_CONNECTION_STRING": "${input:mongo-connection-string}"
      }
    }
  }
}